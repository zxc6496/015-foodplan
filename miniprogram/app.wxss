/** 全局样式 - 暖橙+白色极简风格 **/

page {
  --primary: #FF8C42;
  --primary-light: #FFF0E6;
  --bg: #FFF8F0;
  --white: #FFFFFF;
  --text: #333333;
  --text-light: #888888;
  --border: #EEEEEE;
  --success: #52C41A;
  --danger: #FF4D4F;

  background-color: var(--bg);
  font-size: 28rpx;
  color: var(--text);
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', sans-serif;
  box-sizing: border-box;
}

button {
  background: initial;
  padding: 0;
  margin: 0;
}

button:focus {
  outline: 0;
}

button::after {
  border: none;
}

/* 通用按钮 */
.btn-primary {
  background-color: var(--primary);
  color: #fff;
  border-radius: 44rpx;
  font-size: 30rpx;
  padding: 20rpx 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-primary:active {
  opacity: 0.8;
}

.btn-outline {
  background-color: transparent;
  color: var(--primary);
  border: 2rpx solid var(--primary);
  border-radius: 44rpx;
  font-size: 28rpx;
  padding: 16rpx 40rpx;
}

/* 卡片 */
.card {
  background-color: var(--white);
  border-radius: 16rpx;
  padding: 24rpx;
  margin: 20rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

/* 免责声明 */
.disclaimer {
  text-align: center;
  font-size: 22rpx;
  color: #bbb;
  padding: 24rpx 32rpx;
  line-height: 1.6;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
  color: var(--text-light);
}

.empty-state .empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}