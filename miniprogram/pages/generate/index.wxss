/* 生成菜谱页面样式 */
.page {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag {
  padding: 10rpx 24rpx;
  background-color: #FFF0E6;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #FF8C42;
}

.empty-hint {
  color: #bbb;
  font-size: 26rpx;
  text-align: center;
  padding: 20rpx 0;
}

/* 参数行 */
.param-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.param-row:last-child {
  border-bottom: none;
}

.param-label {
  font-size: 28rpx;
  color: #333;
  flex-shrink: 0;
  margin-right: 24rpx;
}

/* 步进器 */
.stepper {
  display: flex;
  align-items: center;
  gap: 0;
}

.step-btn {
  width: 60rpx;
  height: 60rpx;
  line-height: 60rpx;
  text-align: center;
  background-color: #FFF0E6;
  color: #FF8C42;
  font-size: 32rpx;
  font-weight: bold;
}

.step-btn:first-child {
  border-radius: 12rpx 0 0 12rpx;
}

.step-btn:last-child {
  border-radius: 0 12rpx 12rpx 0;
}

.step-btn.disabled {
  color: #ccc;
  background-color: #f5f5f5;
}

.step-value {
  width: 100rpx;
  text-align: center;
  font-size: 28rpx;
  background-color: #fff;
  height: 60rpx;
  line-height: 60rpx;
  border: 2rpx solid #FFF0E6;
}

/* 选项组 */
.options {
  display: flex;
  gap: 16rpx;
}

.option {
  padding: 12rpx 32rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  background-color: #f5f5f5;
  color: #666;
}

.option.active {
  background-color: #FF8C42;
  color: #fff;
}

/* 忌口 */
.taboos {
  flex-direction: column;
  align-items: flex-start;
}

.taboo-input-row {
  width: 100%;
  margin: 16rpx 0;
}

.taboo-input {
  width: 100%;
  height: 70rpx;
  background-color: #FFF8F0;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 26rpx;
  box-sizing: border-box;
  border: 2rpx solid #FFE0C0;
}

.taboo-tag {
  background-color: #FFF0F0;
  color: #FF4D4F;
}

.taboo-tag .remove {
  margin-left: 8rpx;
}

/* 生成按钮 */
.btn-area {
  padding: 30rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.generate-btn {
  width: 100%;
  height: 88rpx;
  font-size: 32rpx;
}

.generate-btn[disabled] {
  background-color: #ccc;
  color: #fff;
}

/* 加载 */
.loading-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx;
  color: #FF8C42;
  font-size: 28rpx;
  gap: 20rpx;
}

.loading-dot {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 4rpx solid #FFE0C0;
  border-top-color: #FF8C42;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* 菜谱卡片 */
.meal-card {
  margin-top: 4rpx;
}

.meal-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.meal-icon {
  font-size: 36rpx;
}

.meal-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  flex: 1;
}

.meal-time {
  font-size: 24rpx;
  color: #FF8C42;
  background-color: #FFF0E6;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.meal-meta {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 6rpx;
}

.meal-calories {
  font-size: 22rpx;
  color: #FF8C42;
  background-color: #FFF0E6;
  padding: 2rpx 14rpx;
  border-radius: 20rpx;
}

.dish-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #FF8C42;
  margin-bottom: 12rpx;
}

.dish-ingredients,
.dish-steps {
  font-size: 26rpx;
  color: #666;
  line-height: 1.8;
  margin-bottom: 8rpx;
}

.label {
  color: #333;
  font-weight: 500;
}

.action-row {
  display: flex;
  justify-content: flex-end;
  margin-top: 12rpx;
}

.small {
  padding: 8rpx 24rpx;
  font-size: 24rpx;
}

/* AI 声明 */
.ai-disclaimer {
  text-align: center;
  font-size: 22rpx;
  color: #bbb;
  padding: 16rpx 32rpx;
}