/* 食材录入页面样式 */
.page {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

/* 输入区域 */
.input-section {
  margin-top: 20rpx;
}

.input-row {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.ingredient-input {
  flex: 1;
  height: 80rpx;
  background-color: #FFF8F0;
  border-radius: 40rpx;
  padding: 0 32rpx;
  font-size: 28rpx;
  border: 2rpx solid #FFE0C0;
}

.add-btn {
  width: 120rpx;
  height: 80rpx;
  line-height: 80rpx;
  background-color: #FF8C42;
  color: #fff;
  border-radius: 40rpx;
  font-size: 28rpx;
  text-align: center;
}

/* 拍照区域 */
.camera-section {
  margin-top: 24rpx;
}

.camera-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  height: 80rpx;
  background-color: #FFF0E6;
  color: #FF8C42;
  border-radius: 40rpx;
  font-size: 28rpx;
  border: 2rpx dashed #FFC080;
}

.camera-tip {
  text-align: center;
  color: #FF8C42;
  font-size: 24rpx;
  margin-top: 12rpx;
}

/* 快速选择 */
.quick-select {
  margin-top: 20rpx;
}

.category-group {
  margin-bottom: 20rpx;
}

.category-name {
  font-size: 26rpx;
  color: #888;
  margin-bottom: 12rpx;
}

.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.ingredient-tag {
  padding: 12rpx 28rpx;
  background-color: #F5F5F5;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #666;
}

.ingredient-tag.selected {
  background-color: #FF8C42;
  color: #fff;
}

/* 已添加食材 */
.ingredient-list {
  margin-top: 20rpx;
}

.clear-all {
  font-size: 24rpx;
  color: #FF4D4F;
  font-weight: 400;
}

.tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.selected-tag {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 20rpx;
  background-color: #FFF0E6;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #FF8C42;
  border: 2rpx solid #FFE0C0;
}

.delete-icon {
  width: 32rpx;
  height: 32rpx;
  line-height: 30rpx;
  text-align: center;
  background-color: #FF4D4F;
  color: #fff;
  border-radius: 50%;
  font-size: 24rpx;
}