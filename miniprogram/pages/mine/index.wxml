<!-- 我的页面 -->
<view class="page {{theme === 'dark' ? 'dark-theme' : ''}}">
  <!-- 头部：用户信息 -->
  <view class="header">
    <view class="user-card">
      <image class="avatar-img" wx:if="{{userInfo.avatarUrl}}" src="{{userInfo.avatarUrl}}"></image>
      <view class="avatar-placeholder" wx:else>🍳</view>
      <view class="user-detail">
        <text class="user-name" wx:if="{{userInfo.nickName}}">{{userInfo.nickName}}</text>
        <text class="user-name guest" wx:else>未登录</text>
        <text class="user-id" wx:if="{{openIdShort}}">ID: {{openIdShort}}</text>
        <text class="user-id" wx:else>登录后查看更多功能</text>
      </view>
      <view class="user-actions">
        <view class="login-btn" wx:if="{{!userInfo}}" bindtap="getUserProfile">登录</view>
        <view class="logout-btn" wx:else bindtap="logout">退出</view>
      </view>
    </view>
    <view class="app-title">AI 三餐菜谱规划工具</view>
    <view class="app-subtitle">智能搭配家常菜式</view>
  </view>

  <!-- 设置 -->
  <view class="card">
    <view class="menu-item" bindtap="goSettings">
      <text class="menu-text">⚙️ 设置</text>
      <image class="arrow" src="/images/arrow.svg"></image>
    </view>
  </view>

  <!-- 历史菜谱 -->
  <view class="card">
    <view class="section-header">
      <text class="section-title">📋 历史记录</text>
      <text class="action-btn" bindtap="clearHistory" wx:if="{{history.length > 0}}">清空</text>
    </view>
    <view wx:if="{{historyLoading}}">
      <text class="loading-text">加载中…</text>
    </view>
    <view wx:elif="{{history.length > 0}}">
      <view
        class="history-item"
        wx:for="{{history}}"
        wx:key="index"
        wx:for-item="hitem"
        bindtap="viewHistory"
        data-index="{{index}}"
      >
        <view class="history-time">{{hitem.time}}</view>
        <view class="history-dishes">{{hitem.dishNames}}</view>
        <image class="arrow" src="/images/arrow.svg"></image>
      </view>
    </view>
    <view class="empty-hint" wx:else>暂无历史记录</view>
  </view>

  <!-- 收藏菜谱 -->
  <view class="card">
    <view class="section-header">
      <text class="section-title">⭐ 我的收藏</text>
      <text class="action-btn" bindtap="clearFavorites" wx:if="{{favorites.length > 0}}">清空</text>
    </view>
    <view wx:if="{{favLoading}}">
      <text class="loading-text">加载中…</text>
    </view>
    <view wx:elif="{{favorites.length > 0}}">
      <view
        class="fav-item"
        wx:for="{{favorites}}"
        wx:key="index"
        bindtap="viewFavorite"
        data-index="{{index}}"
      >
        <view class="fav-dish-name">{{item.dish.name}}</view>
        <view class="fav-meal">{{item.meal}}</view>
        <view class="fav-time">⏱ {{item.dish.cookTime}}分钟</view>
        <image class="arrow" src="/images/arrow.svg"></image>
      </view>
    </view>
    <view class="empty-hint" wx:else>暂无收藏菜谱</view>
  </view>

  <!-- 我的菜谱（课程作业） -->
  <view class="card">
    <view class="section-header">
      <text class="section-title">📝 我的菜谱</text>
    </view>
    <view class="menu-item" bindtap="goMyRecipes">
      <text class="menu-text">添加、管理、筛选我的菜谱记录</text>
      <image class="arrow" src="/images/arrow.svg"></image>
    </view>
  </view>

  <!-- 免责声明 -->
  <view class="disclaimer">本工具为课程演示项目，仅提供家常菜谱搭配参考，不提供任何医疗、营养、健康指导服务</view>
</view>
