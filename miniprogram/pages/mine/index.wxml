<!-- 我的页面 -->
<view class="page">
  <!-- 头部 -->
  <view class="header">
    <view class="avatar">🍳</view>
    <view class="title">AI 三餐菜谱规划工具</view>
    <view class="subtitle">智能搭配家常菜式</view>
  </view>

  <!-- 历史菜谱 -->
  <view class="card">
    <view class="section-header">
      <text class="section-title">📋 历史记录</text>
      <text class="action-btn" bindtap="clearHistory" wx:if="{{history.length > 0}}">清空</text>
    </view>
    <view wx:if="{{history.length > 0}}">
      <view
        class="history-item"
        wx:for="{{history}}"
        wx:key="index"
        wx:for-item="hitem"
        bindtap="viewHistory"
        data-index="{{index}}"
      >
        <view class="history-time">{{hitem.time}}</view>
        <view class="history-dishes">{{hitem.dishNames}}</view>
        <image class="arrow" src="/images/arrow.svg"></image>
      </view>
    </view>
    <view class="empty-hint" wx:else>暂无历史记录</view>
  </view>

  <!-- 收藏菜谱 -->
  <view class="card">
    <view class="section-header">
      <text class="section-title">⭐ 我的收藏</text>
      <text class="action-btn" bindtap="clearFavorites" wx:if="{{favorites.length > 0}}">清空</text>
    </view>
    <view wx:if="{{favorites.length > 0}}">
      <view
        class="fav-item"
        wx:for="{{favorites}}"
        wx:key="index"
        bindtap="viewFavorite"
        data-index="{{index}}"
      >
        <view class="fav-dish-name">{{item.dish.name}}</view>
        <view class="fav-meal">{{item.meal}}</view>
        <view class="fav-time">⏱ {{item.dish.cookTime}}分钟</view>
        <image class="arrow" src="/images/arrow.svg"></image>
      </view>
    </view>
    <view class="empty-hint" wx:else>暂无收藏菜谱</view>
  </view>

  <!-- 免责声明 -->
  <view class="disclaimer">本工具为课程演示项目，仅提供家常菜谱搭配参考，不提供任何医疗、营养、健康指导服务</view>
</view>