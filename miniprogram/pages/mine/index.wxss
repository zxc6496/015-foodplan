/* 我的页面 */
.page {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* 头部 */
.header {
  background: linear-gradient(135deg, #FF8C42, #FFB380);
  padding: 60rpx 32rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  color: #fff;
}

.avatar {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.title {
  font-size: 36rpx;
  font-weight: 600;
}

.subtitle {
  font-size: 24rpx;
  opacity: 0.8;
  margin-top: 8rpx;
}

.card {
  margin-top: 20rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.action-btn {
  font-size: 24rpx;
  color: #FF4D4F;
}

/* 历史记录 */
.history-item,
.fav-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
  gap: 12rpx;
}

.history-item:last-child,
.fav-item:last-child {
  border-bottom: none;
}

.history-time {
  font-size: 22rpx;
  color: #bbb;
  flex-shrink: 0;
  width: 160rpx;
}

.history-dishes {
  flex: 1;
  font-size: 26rpx;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.fav-dish-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.fav-meal {
  font-size: 24rpx;
  color: #FF8C42;
  background-color: #FFF0E6;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.fav-time {
  font-size: 24rpx;
  color: #888;
  flex: 1;
  text-align: right;
}

.arrow {
  width: 24rpx;
  height: 24rpx;
  transform: rotate(90deg);
  flex-shrink: 0;
}

.empty-hint {
  color: #ccc;
  font-size: 26rpx;
  text-align: center;
  padding: 40rpx 0;
}