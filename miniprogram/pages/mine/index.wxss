/* 我的页面 */
.page {
  min-height: 100vh;
  padding-bottom: 40rpx;
  background-color: #FFF8F0;
}

.page.dark-theme {
  background-color: #1a1a2e;
}

/* 头部 */
.header {
  background: linear-gradient(135deg, #FF8C42, #FFB380);
  padding: 60rpx 32rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  color: #fff;
}

.user-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 20rpx;
  width: 100%;
  background-color: rgba(255, 255, 255, 0.15);
  border-radius: 16rpx;
  padding: 20rpx;
}

.avatar-img {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.5);
}

.avatar-placeholder {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background-color: rgba(255, 255, 255, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}

.user-detail {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.user-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
}

.user-name.guest {
  font-size: 28rpx;
  opacity: 0.8;
}

.user-id {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
}

.user-actions {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.login-btn,
.logout-btn {
  font-size: 24rpx;
  padding: 8rpx 24rpx;
  border-radius: 20rpx;
  text-align: center;
  min-width: 100rpx;
}

.login-btn {
  background-color: #fff;
  color: #FF8C42;
}

.logout-btn {
  background-color: rgba(255, 255, 255, 0.3);
  color: #fff;
  border: 2rpx solid rgba(255, 255, 255, 0.5);
}

.app-title {
  font-size: 36rpx;
  font-weight: 600;
}

.app-subtitle {
  font-size: 24rpx;
  opacity: 0.8;
  margin-top: 8rpx;
}

.card {
  margin-top: 20rpx;
  background-color: #fff;
  margin-left: 20rpx;
  margin-right: 20rpx;
  border-radius: 16rpx;
  padding: 24rpx;
}

.page.dark-theme .card {
  background-color: #16213e;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.page.dark-theme .section-title {
  color: #eee;
}

.action-btn {
  font-size: 24rpx;
  color: #FF4D4F;
}

/* 加载提示 */
.loading-text {
  text-align: center;
  color: #bbb;
  font-size: 26rpx;
  padding: 30rpx 0;
}

/* 历史记录 */
.history-item,
.fav-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
  gap: 12rpx;
}

.page.dark-theme .history-item,
.page.dark-theme .fav-item {
  border-bottom-color: #2a2a4a;
}

.history-item:last-child,
.fav-item:last-child {
  border-bottom: none;
}

.history-time {
  font-size: 22rpx;
  color: #bbb;
  flex-shrink: 0;
  width: 160rpx;
}

.history-dishes {
  flex: 1;
  font-size: 26rpx;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.page.dark-theme .history-dishes {
  color: #ddd;
}

.fav-dish-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.page.dark-theme .fav-dish-name {
  color: #ddd;
}

.fav-meal {
  font-size: 24rpx;
  color: #FF8C42;
  background-color: #FFF0E6;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.fav-time {
  font-size: 24rpx;
  color: #888;
  flex: 1;
  text-align: right;
}

.arrow {
  width: 24rpx;
  height: 24rpx;
  transform: rotate(90deg);
  flex-shrink: 0;
}

.empty-hint {
  color: #ccc;
  font-size: 26rpx;
  text-align: center;
  padding: 40rpx 0;
}

/* 菜单项 */
.menu-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.page.dark-theme .menu-item {
  border-bottom-color: #2a2a4a;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-text {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.page.dark-theme .menu-text {
  color: #ddd;
}