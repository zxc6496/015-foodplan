<!-- 添加菜谱页面 - 独立表单页 -->
<view class="page">
  <view class="form-card">
    <view class="form-title">{{editingId ? '编辑菜谱' : '添加新菜谱'}}</view>

    <view class="form-group">
      <text class="form-label">餐次</text>
      <view class="meal-options">
        <view class="meal-opt {{formData.meal === '早餐' ? 'active' : ''}}" bindtap="selectMeal" data-meal="早餐">早餐</view>
        <view class="meal-opt {{formData.meal === '午餐' ? 'active' : ''}}" bindtap="selectMeal" data-meal="午餐">午餐</view>
        <view class="meal-opt {{formData.meal === '晚餐' ? 'active' : ''}}" bindtap="selectMeal" data-meal="晚餐">晚餐</view>
      </view>
    </view>

    <view class="form-group">
      <text class="form-label">菜名</text>
      <input class="form-input" placeholder="请输入菜名" value="{{formData.dishName}}" bindinput="onDishNameInput" />
    </view>

    <view class="form-group">
      <text class="form-label">食材</text>
      <input class="form-input" placeholder="请输入食材，逗号分隔" value="{{formData.ingredients}}" bindinput="onIngredientsInput" />
    </view>

    <view class="form-group">
      <text class="form-label">用餐人数</text>
      <input class="form-input" type="number" placeholder="请输入人数" value="{{formData.peopleCount}}" bindinput="onPeopleCountInput" />
    </view>
  </view>

  <view class="btn-area">
    <button class="btn-submit" bindtap="submitForm">保存</button>
    <button class="btn-cancel" bindtap="goBack">返回</button>
  </view>
</view>
