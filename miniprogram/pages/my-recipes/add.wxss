/* 添加菜谱页面 */
.page {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 24rpx;
}

.form-card {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 32rpx 24rpx;
}

.form-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  text-align: center;
  margin-bottom: 32rpx;
}

.form-group {
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 12rpx;
  display: block;
}

.form-input {
  width: 100%;
  height: 80rpx;
  background-color: #f5f5f5;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.meal-options {
  display: flex;
  gap: 16rpx;
}

.meal-opt {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  background-color: #f5f5f5;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #666;
}

.meal-opt.active {
  background-color: #FF8C42;
  color: #fff;
}

.btn-area {
  margin-top: 40rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.btn-submit {
  height: 88rpx;
  background-color: #FF8C42;
  color: #fff;
  font-size: 30rpx;
  border-radius: 44rpx;
  line-height: 88rpx;
}

.btn-cancel {
  height: 88rpx;
  background-color: #f5f5f5;
  color: #666;
  font-size: 30rpx;
  border-radius: 44rpx;
  line-height: 88rpx;
}
