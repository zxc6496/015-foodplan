/* 我的菜谱列表页面样式 */
.page {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 120rpx;
}

/* 统计卡片 */
.stats-card {
  display: flex;
  background: linear-gradient(135deg, #FF8C42, #FFB380);
  padding: 30rpx 20rpx;
  margin-bottom: 20rpx;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.stat-num {
  font-size: 44rpx;
  font-weight: 700;
  color: #fff;
}

.stat-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
}

/* 搜索筛选 */
.filter-bar {
  background-color: #fff;
  padding: 20rpx 24rpx;
  margin-bottom: 16rpx;
}

.search-input {
  width: 100%;
  height: 72rpx;
  background-color: #f5f5f5;
  border-radius: 36rpx;
  padding: 0 30rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  margin-bottom: 16rpx;
}

.filter-btns {
  display: flex;
  gap: 16rpx;
}

.filter-btn {
  padding: 10rpx 28rpx;
  background-color: #f5f5f5;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #666;
}

.filter-btn.active {
  background-color: #FF8C42;
  color: #fff;
}

/* 列表 */
.list-area {
  padding: 0 24rpx;
}

.empty-tip {
  text-align: center;
  color: #bbb;
  font-size: 28rpx;
  padding: 80rpx 0;
}

.recipe-card {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.card-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.meal-tag {
  font-size: 22rpx;
  background-color: #FFF0E6;
  color: #FF8C42;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.dish-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.card-body {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  font-size: 26rpx;
  color: #666;
}

.card-actions {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  margin-top: 16rpx;
}

.btn-edit {
  font-size: 24rpx;
  color: #FF8C42;
  background-color: #FFF0E6;
  padding: 8rpx 24rpx;
  border-radius: 24rpx;
  line-height: 1.6;
}

.btn-delete {
  font-size: 24rpx;
  color: #FF4D4F;
  background-color: #FFF0F0;
  padding: 8rpx 24rpx;
  border-radius: 24rpx;
  line-height: 1.6;
}

/* 添加按钮 */
.add-btn {
  position: fixed;
  right: 40rpx;
  bottom: 80rpx;
  width: 100rpx;
  height: 100rpx;
  background-color: #FF8C42;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 20rpx rgba(255, 140, 66, 0.4);
  z-index: 50;
}

.add-btn text {
  font-size: 56rpx;
  color: #fff;
  line-height: 1;
}
