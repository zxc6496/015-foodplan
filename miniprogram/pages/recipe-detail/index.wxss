/* 菜谱详情页 */
.page {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* 顶部 */
.header {
  background: linear-gradient(135deg, #FF8C42, #FFB380);
  padding: 50rpx 32rpx 40rpx;
  color: #fff;
}

.meal-badge {
  display: inline-block;
  font-size: 24rpx;
  background-color: rgba(255, 255, 255, 0.25);
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  margin-bottom: 16rpx;
}

.dish-name {
  font-size: 44rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
}

.meta {
  display: flex;
  gap: 32rpx;
  font-size: 26rpx;
  opacity: 0.9;
  flex-wrap: wrap;
}

.calories-text {
  font-size: 24rpx;
  opacity: 0.85;
}

.card {
  margin-top: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.ingredient-text,
.steps-text {
  font-size: 28rpx;
  color: #555;
  line-height: 2;
  white-space: pre-wrap;
}

.btn-area {
  padding: 30rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}

.btn-primary,
.btn-outline {
  width: 100%;
  height: 88rpx;
  font-size: 30rpx;
}

.share-btn {
  background-color: transparent !important;
  color: #FF8C42 !important;
  border: 2rpx solid #FF8C42 !important;
  border-radius: 44rpx !important;
}

.ai-disclaimer {
  text-align: center;
  font-size: 22rpx;
  color: #bbb;
  padding: 16rpx 32rpx;
}